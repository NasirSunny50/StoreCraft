# Copy to .env and fill in. NEVER commit .env.

# PostgreSQL (Neon/Supabase in prod; local Docker in dev)
# DATABASE_URL = pooled connection (runtime). DIRECT_URL = direct/non-pooled
# connection (migrations). On Neon these differ; locally they're the same.
DATABASE_URL="postgresql://storecraft:storecraft@localhost:5433/storecraft?schema=public"
DIRECT_URL="postgresql://storecraft:storecraft@localhost:5433/storecraft?schema=public"

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
# On Vercel, set AUTH_TRUST_HOST=true so Auth.js accepts the deployment host.
AUTH_TRUST_HOST="true"

# Cloudinary — required in production for image uploads. When all three are set,
# uploads go to Cloudinary; otherwise they fall back to local /public/uploads.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# Email notifications (Resend — free tier). When RESEND_API_KEY is unset,
# emails are skipped and logged (local dev / tests). EMAIL_FROM must be a
# verified sender; Resend's test sender works out of the box.
RESEND_API_KEY=""
EMAIL_FROM="StoreCraft <onboarding@resend.dev>"

# SSLCommerz (Phase 5)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
