# Copy to .env and fill in. NEVER commit .env.

# PostgreSQL (Neon/Supabase in prod; local Docker in dev)
DATABASE_URL="postgresql://storecraft:storecraft@localhost:5433/storecraft?schema=public"

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Cloudinary (Phase 2+)
CLOUDINARY_URL=""
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""

# SSLCommerz (Phase 5)
SSLCOMMERZ_STORE_ID=""
SSLCOMMERZ_STORE_PASSWORD=""
